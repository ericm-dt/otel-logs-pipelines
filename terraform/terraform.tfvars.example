# Terraform deployment variables for EKS + OpenTelemetry demo
# Copy this file to terraform.tfvars and adjust values for your environment.

# AWS / Cluster
region             = "us-east-1"
cluster_name       = "otel-demo-cluster"
kubernetes_version = "1.32"

# Node group sizing
node_count    = 3
instance_type = "t3.large"
disk_size_gb  = 50

# Networking
# Mode A (default): use default VPC + existing subnets
# vpc_cidr = null
# existing_vpc_id = null
# public_subnet_cidrs = null
# private_subnet_cidrs = null

# Mode B: use default (or existing_vpc_id) VPC + create dedicated project subnets
# existing_vpc_id      = null
# public_subnet_cidrs  = ["172.31.100.0/24", "172.31.101.0/24"]
# private_subnet_cidrs = ["172.31.110.0/24", "172.31.111.0/24"]

# Mode C: create new VPC (subnets auto-derived if not set)
vpc_cidr             = null
existing_vpc_id      = null
public_subnet_cidrs  = null
private_subnet_cidrs = null

# whether or not to deploy the k8s resources
deploy_otel_demo = false

# OTel demo Helm release
otel_demo_namespace     = "otel-demo"
otel_demo_chart_version = "0.40.5"

# Observability/runtime profile values are shown as complete copy/paste blocks
# in the "Full scenario blocks" section near the end of this file.
# Uncomment and customize one profile there.

# Optional collector customization
# Add non-sensitive environment variables to the collector container.
# Sensitive credentials (DT_TENANT_URL, DT_API_TOKEN) are managed separately below.
otel_collector_env = {
  OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE = "delta"
  # EXAMPLE_ENV = "value"
}

# Dynatrace credentials — these are stored as a Kubernetes secret at deploy
# time and never appear in Helm values or plan output.
# Required when deploy_otel_demo = true and using the Dynatrace exporter.
dt_tenant_url = "https://<your-environment-id>.live.dynatrace.com"

# Recommended: split Dynatrace tokens by responsibility.
# Operator token scopes (deployment/OneAgent):
# - ReadConfig
# - WriteConfig
# - InstallerDownload
# - DataExport
dt_operator_api_token = "dt0c01.<your-operator-token>"

# OTel ingest token scopes (collector OTLP export):
# - openTelemetryTrace.ingest
# - metrics.ingest
# - logs.ingest
dt_ingest_api_token = "dt0c01.<your-ingest-token>"

# Optional legacy fallback: single shared token used for both operator and ingest.
# Keep null when using split tokens above.
dt_api_token = null

# Collector config is scenario-dependent; use one full profile block below.
# Keep empty by default.
otel_collector_config = {}

# ---------------------------------------------------------------------------
# Full scenario blocks (copy/paste one profile and adjust values)
# ---------------------------------------------------------------------------

# Scenario 1: Pure OTel (SDK -> Collector -> Dynatrace)
