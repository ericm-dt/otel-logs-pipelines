# Terraform deployment variables for EKS + OpenTelemetry demo
# Copy to terraform.tfvars and edit values for your environment.
#
# IMPORTANT:
# - Edit the ENVIRONMENT VALUES sections below.
# - Do not rely on this file for phase toggles. Phase overlays in
#   terraform/phases/*.tfvars override the toggle variables at runtime.

# =============================================================================
# ENVIRONMENT VALUES (EDIT THESE)
# =============================================================================

# AWS / Cluster
region             = "us-east-1"
cluster_name       = "my-bindplane-sandbox" #must be unique in your AWS account/region!
kubernetes_version = "1.33"

# Node group sizing
node_count    = 3
instance_type = "t3.large"
disk_size_gb  = 50

# Networking
Mode A (default): use default VPC + existing subnets
vpc_cidr = null
existing_vpc_id = null
public_subnet_cidrs = null
private_subnet_cidrs = null

# Mode B: use default (or existing_vpc_id) VPC + create dedicated project subnets
# existing_vpc_id      = null
# public_subnet_cidrs  = ["172.31.100.0/24", "172.31.101.0/24"]
# private_subnet_cidrs = ["172.31.110.0/24", "172.31.111.0/24"]

# Mode C: create new VPC (subnets auto-derived if not set)
# vpc_cidr             = null
# existing_vpc_id      = null
# public_subnet_cidrs  = null
# private_subnet_cidrs = null

# Bindplane Cloud provider connectivity/auth.
# Required when deploy_bindplane_controlplane=true in phase overlays.
bindplane_provider_remote_url = "https://app.bindplane.com"
bindplane_provider_api_key    = "<your-bindplane-api-key>"
# Optional basic auth alternative
bindplane_provider_username = null
bindplane_provider_password = null

# Set true only for test environments with self-signed certs.
bindplane_provider_tls_skip_verify = false

# Bindplane Cloud agent manifest path.
bindplane_bootstrap_manifest_path = "./bindplane-agent.yaml"

# OTel demo Helm release
otel_demo_namespace     = "otel-demo"
otel_demo_chart_version = "0.40.5"

# Optional environment variable overrides for demo services.
# Leave empty to use chart defaults.
otel_collector_env = {}

# Embedded collector configuration - exports to Bindplane collector
# The demo's embedded collector forwards all telemetry to Bindplane.
otel_collector_config = {
  exporters = {
    otlp = {
      endpoint = "bindplane-node-agent.bindplane-agent.svc.cluster.local:4317"
      tls = {
        insecure = true
      }
    }
  }
  service = {
    pipelines = {
      traces  = { exporters = ["otlp", "otlp/jaeger", "spanmetrics"] }
      metrics = { exporters = ["otlp", "otlphttp/prometheus"] }
      logs    = { exporters = ["otlp", "opensearch"] }
    }
  }
}

# Dynatrace credentials used by embedded collector path.
# Required when deploy_otel_demo=true and deploy_embedded_collector=true.
dt_tenant_url = "https://<your-environment-id>.live.dynatrace.com"

# API token needs:
# - openTelemetryTrace.ingest
# - metrics.ingest
# - logs.ingest
dt_api_token = "dt0c01.<your-api-token>"

# =============================================================================
# OPTIONAL SELF-HOSTED BINDPLANE (ADVANCED/NOT CLOUD-DEFAULT)
# =============================================================================

# Leave disabled unless intentionally running self-hosted Bindplane.
deploy_bindplane_server = false
bindplane_namespace     = "bindplane"
bindplane_chart_version = "1.34.0"

# Required only when deploy_bindplane_server=true
bindplane_admin_username = ""
bindplane_admin_password = ""
bindplane_sessions_secret = ""
bindplane_license         = ""

# Required only when deploy_bindplane_server=true:
# explicitly set backend.type in Helm values.
bindplane_helm_values = {
  backend = {
    type = "bbolt"
    bbolt = {
      volumeSize = "10Gi"
    }
  }
  image = {
    tag = "v1.98.0"
  }
}

# =============================================================================
# PHASE-CONTROLLED TOGGLES (DO NOT EDIT FOR NORMAL WORKFLOW)
# =============================================================================
# These values are shown for clarity only. They are overridden by:
# - phases/01-infra.tfvars
# - phases/02a-bindplane.tfvars
# - phases/02b-bootstrap-collector.tfvars
# - phases/03-demo-external-collector.tfvars

deploy_otel_demo                 = false
deploy_bindplane_controlplane    = false
deploy_bindplane_cloud_bootstrap = false
deploy_embedded_collector        = true
