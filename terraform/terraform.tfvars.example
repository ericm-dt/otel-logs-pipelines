# Terraform deployment variables for EKS + Bank of Anthos observability demo
# Copy this file to terraform.tfvars and adjust values for your environment.

# AWS / Cluster
region             = "us-east-1"
cluster_name       = "boa-observability-demo"
kubernetes_version = "1.32"

# Node group sizing
node_count    = 3
instance_type = "t3.large"
disk_size_gb  = 50

# Networking (Mode A default: use default VPC + existing subnets)
vpc_cidr             = null
existing_vpc_id      = null
public_subnet_cidrs  = null
private_subnet_cidrs = null

# ---------------------------------------------------------------------------
# Bank of Anthos
# ---------------------------------------------------------------------------
deploy_bank_of_anthos    = true
bank_of_anthos_namespace = "bank-of-anthos"
bank_of_anthos_version   = "v0.6.5"

# JWT keys are generated automatically by Terraform.
# Optional override if you need fixed externally managed keys:
# bank_of_anthos_jwt_private_key = "-----BEGIN RSA PRIVATE KEY----- ..."
# bank_of_anthos_jwt_public_key  = "-----BEGIN PUBLIC KEY----- ..."

# Pass-through Helm values — anything in charts/bank-of-anthos/values.yaml.
# See the profiles/ directory for complete scenario examples.
bank_of_anthos_helm_values = {
  # loadgenerator = { enabled = true }
  #
  # Apply OTel auto-instrumentation annotations to all pods (requires OTel Operator):
  # global = {
  #   podAnnotations = {
  #     "instrumentation.opentelemetry.io/inject-java"   = "true"
  #     "instrumentation.opentelemetry.io/inject-python" = "true"
  #   }
  # }
}

# ---------------------------------------------------------------------------
# Dynatrace credentials
# ---------------------------------------------------------------------------
dt_tenant_url         = "https://<your-environment-id>.live.dynatrace.com"
dt_operator_api_token = "dt0c01.<your-operator-token>"   # scopes: ReadConfig, WriteConfig, InstallerDownload, DataExport
dt_ingest_api_token   = "dt0c01.<your-ingest-token>"     # scopes: openTelemetryTrace.ingest, metrics.ingest, logs.ingest

# Optional dedicated token for Terraform settings-as-code via dynatrace provider.
# If null, Terraform reuses dt_operator_api_token.
# Required scopes for this repo's settings layer: settings.read, settings.write
dt_settings_api_token = null

# ---------------------------------------------------------------------------
# Dynatrace Operator
#
# Two-step workflow for initial deployment:
#   Step 1: deploy_dynatrace_operator=true, deploy_dynakube=false  → Operator + CRDs
#   Step 2: deploy_dynakube=true, dynakube_spec populated          → OneAgent
#
# dt_operator_helm_values: full Helm values pass-through.
#   Reference: https://github.com/Dynatrace/dynatrace-operator/tree/main/config/helm/chart/default
#
# dynakube_spec: full DynaKube CR spec (apiUrl and tokens are injected automatically).
#   Reference: https://docs.dynatrace.com/docs/setup-and-configuration/setup-on-k8s/reference/dynakube
# ---------------------------------------------------------------------------
deploy_dynatrace_operator = false
deploy_dynakube           = false
deploy_dynatrace_settings_layer = false

# Controls for Terraform-managed Dynatrace tenant settings
dynatrace_enable_python_monitored_technology = true
dynatrace_enable_bank_of_anthos_process_rule = true
dynatrace_enable_global_auto_process_monitoring = true
dynatrace_enable_gunicorn_process_rule = true

dt_operator_helm_values = {}

# cloudNativeFullStack — code-level instrumentation + host monitoring (recommended)
dynakube_spec = {
  oneAgent = {
    cloudNativeFullStack = {}
  }
}

# hostMonitoring only (no code injection):
# dynakube_spec = {
#   oneAgent = {
#     hostMonitoring = {}
#   }
# }

# ---------------------------------------------------------------------------
# Legacy OTel demo (disabled — use Bank of Anthos instead)
# ---------------------------------------------------------------------------
deploy_otel_demo = false

