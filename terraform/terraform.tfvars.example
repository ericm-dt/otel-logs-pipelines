# Scenario 2: OneAgent for traces/metrics + Collector filelog for logs
# First apply:  deploy_dynatrace_operator = true, deploy_dynakube = false
# Second apply: set deploy_dynakube = true together with the values below.
# deploy_otel_demo                  = true
# otel_sdk_disabled                 = true
# collector_logs_collection_enabled = true
# deploy_dynatrace_operator         = true
# deploy_dynakube                   = true
# dynatrace_operator_version        = "v1.8.1"
# oneagent_mode                     = "cloudNativeFullStack"
